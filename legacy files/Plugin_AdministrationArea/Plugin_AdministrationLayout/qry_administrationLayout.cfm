	--->

<CFIF isDefined("ATTRIBUTES.RebuildAdminMenus")>
	<CFLOCK SCOPE="APPLICATION" THROWONTIMEOUT="NO" TYPE="EXCLUSIVE" TIMEOUT="30">
		<CFSET APPLICATION.AdminMenus = Duplicate(AdminMenus)>
	</CFLOCK>
</CFIF>	


<!--- This section of code builds a variable called JS_<menuName> which contains
	- a JavaScript formatted string containing an HTML table for a menu --->
<CFLOOP FROM="1" TO="#ArrayLen(AdminMenus)#" INDEX="menuName">
	<CFSET menuArray = AdminMenus["#menuName#"].Items>
	<CFSAVECONTENT VARIABLE="JS_#menuName#">
		<TABLE STYLE="border-right: 1px outset #999999; border-bottom: 1px outset #999999; border-left: 1px outset #ffffff; border-top: 1px outset #ffffff;  background-color: #E8EAEB; width: 150px;">
  			<CFLOOP FROM="1" TO="#ArrayLen(menuArray)#" INDEX="menuX">
				<CFSET Name = ListFirst(menuArray[menuX], ":")>
				<CFSET URL  = ListRest(menuArray[menuX], ":")>
			<CFOUTPUT>
			<TR> 
			 <TD NOWRAP ID="menu#menuName##menuX#" ><A HREF="#URL#" CLASS="OLmenuLink" onMouseOver="highlightMenuItem('menu#menuName##menuX#')" onMouseOut="unhighlightMenuItem('menu#menuName##menuX#')">#Name#</A></TD>
			</TR>
			</CFOUTPUT>
			</CFLOOP>
		</TABLE>
	</CFSAVECONTENT>
	<CFSET rv = SetVariable("JS_#menuName#", JSStringFormat(Evaluate("JS_#menuName#")))>
</CFLOOP>
</CFSILENT>